OLLAMA_URL=http://localhost:11434/v1
LM_STUDIO_URL=http://localhost:11434/v1
PRIMARY_MODEL=gemma3:4b
CHEAP_MODEL=gemma3:4b
RANDOM_SEED=42
DATABASE_URL=sqlite:///simulation.sqlite3

# Ollama server tuning for AMD Ryzen AI Max / Vulkan GPU execution.
# Set these as Windows user environment variables before starting Ollama.
OLLAMA_VULKAN=1
GGML_VK_VISIBLE_DEVICES=0
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=30m
