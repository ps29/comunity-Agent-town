LLAMA_CPP_URL=http://localhost:8080/v1
PRIMARY_MODEL=gemma3-4b
CHEAP_MODEL=gemma3-4b
RANDOM_SEED=42
DATABASE_URL=sqlite:///simulation.sqlite3

# Optional: set this to let sentence-transformers download embeddings from Hugging Face
# without anonymous request warnings. If omitted, cached embeddings are used when available.
HF_TOKEN=

# llama.cpp Vulkan GPU selection for AMD Ryzen AI Max / Radeon integrated GPUs.
GGML_VK_VISIBLE_DEVICES=0
